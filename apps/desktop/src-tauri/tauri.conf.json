{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Personal Character Agent",
  "version": "0.1.0",
  "identifier": "dev.personal-character-agent.desktop",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://127.0.0.1:5174",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "Mira Floating Companion",
        "width": 1180,
        "height": 760,
        "minWidth": 380,
        "minHeight": 520,
        "resizable": true,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": false,
        "shadow": false,
        "center": true
      },
      {
        "label": "pet",
        "title": "Desktop Pet",
        "url": "index.html?pet=1",
        "width": 360,
        "height": 480,
        "resizable": true,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "shadow": false,
        "skipTaskbar": true,
        "visible": true
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
