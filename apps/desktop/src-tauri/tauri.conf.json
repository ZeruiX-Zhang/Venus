{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Personal Character Agent",
  "version": "0.1.0",
  "identifier": "dev.personal-character-agent.desktop",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://127.0.0.1:5174",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Mira Floating Companion",
        "width": 1180,
        "height": 760,
        "minWidth": 380,
        "minHeight": 520,
        "resizable": true,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": false,
        "shadow": true,
        "center": true
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/icon.ico"]
  }
}
