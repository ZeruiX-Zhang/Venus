    "@personal-character-agent/persona-runtime": "workspace:*",
    "@personal-character-agent/safety-runtime": "workspace:*",
    "@personal-character-agent/shared": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8"
